<UserControl x:Class="BKKleaner.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding [dashboard.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>

                <Border Style="{StaticResource Card}" Background="{DynamicResource Brush.Warning}"
                        Visibility="{Binding ActiveAlert, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="Black" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ActiveAlert}" Foreground="Black" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Metric cards -->
                <UniformGrid Columns="4">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding [dashboard.cpu_temp], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Metric}" Margin="0,6,0,0">
                                <Run Text="{Binding CpuTemp, Mode=OneWay}"/><Run Text=" °C"/>
                            </TextBlock>
                            <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding CpuUsage, Mode=OneWay}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF211;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.AccentSecondary}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding [dashboard.gpu_temp], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Metric}" Margin="0,6,0,0">
                                <Run Text="{Binding GpuTemp, Mode=OneWay}"/><Run Text=" °C"/>
                            </TextBlock>
                            <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding GpuUsage, Mode=OneWay}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEEA0;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Success}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding [dashboard.ram_usage], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource Metric}" Margin="0,6,0,0">
                                <Run Text="{Binding RamUsagePercent, Mode=OneWay}"/><Run Text=" %"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,0">
                                <Run Text="{Binding RamUsedGb, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding RamTotalGb, Mode=OneWay}"/><Run Text=" GB · "/><Run Text="{Binding RamMhz, Mode=OneWay}"/><Run Text=" MHz"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding [dashboard.disk_health], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DiskHealth}" Style="{StaticResource Metric}" Margin="0,6,0,0"/>
                            <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,0">
                                <Run Text="{Binding [dashboard.fps_estimate], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/><Run Text=": ~"/><Run Text="{Binding FpsEstimate, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Quick actions -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding [dashboard.quick_actions], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Command="{Binding QuickCleanRamCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEEA0;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [dashboard.qa_clean_ram], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding QuickCleanTempCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [dashboard.qa_clean_temp], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding GoToOptimizationCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [dashboard.qa_optimize], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding GoToProfilesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [dashboard.qa_profiles], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <TextBlock Text="{Binding QuickActionStatus}" Style="{StaticResource Caption}" Margin="0,10,0,0"
                                   Foreground="{DynamicResource Brush.Success}"
                                   Visibility="{Binding QuickActionStatus, Converter={StaticResource NullToCollapsed}}"/>
                    </StackPanel>
                </Border>

                <!-- Scores -->
                <UniformGrid Columns="2">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding [dashboard.health_score], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                            <TextBlock Text="{Binding HealthScore}" Style="{StaticResource Metric}"
                                       Foreground="{DynamicResource Brush.Success}"/>
                            <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding HealthScore, Mode=OneWay}"
                                         Foreground="{DynamicResource Brush.Success}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding [dashboard.optimization_score], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                            <TextBlock Text="{Binding OptimizationScore}" Style="{StaticResource Metric}"
                                       Foreground="{DynamicResource Brush.AccentSecondary}"/>
                            <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding OptimizationScore, Mode=OneWay}"
                                         Foreground="{DynamicResource Brush.AccentSecondary}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Live graphs -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding [dashboard.live_graphs], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="CPU %" Style="{StaticResource Caption}"/>
                                <ui:LiveGraph Values="{Binding CpuHistory}" Height="90"
                                              Stroke="{DynamicResource Brush.GraphLine}" Fill="{DynamicResource Brush.GraphFill}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="GPU %" Style="{StaticResource Caption}"/>
                                <ui:LiveGraph Values="{Binding GpuHistory}" Height="90"
                                              Stroke="{DynamicResource Brush.AccentSecondary}" Fill="{DynamicResource Brush.GraphFill}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="RAM %" Style="{StaticResource Caption}"/>
                                <ui:LiveGraph Values="{Binding RamHistory}" Height="90"
                                              Stroke="{DynamicResource Brush.Success}" Fill="{DynamicResource Brush.GraphFill}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- System info + top processes -->
                <UniformGrid Columns="2">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding [dashboard.system_info], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [dashboard.machine], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MachineName}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="OS" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OsDescription}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CpuName}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="GPU" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GpuName}" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="RAM" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TotalRam}" FontSize="12" Margin="0,2"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding [dashboard.uptime], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,2,12,2"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Uptime}" FontSize="12" Margin="0,2"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{Binding [dashboard.top_processes], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                            <ItemsControl ItemsSource="{Binding TopProcesses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,3">
                                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Caption}" VerticalAlignment="Center">
                                                <Run Text="{Binding MemoryMb, Mode=OneWay, StringFormat={}{0:0}}"/><Run Text=" MB"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding QuickActionStatus}"/>
    </Grid>
</UserControl>
