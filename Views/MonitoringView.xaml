<UserControl x:Class="BKKleaner.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" VerticalAlignment="Top"
                        Command="{Binding ExportCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding [monitoring.export], Source={x:Static loc:Loc.Instance}}"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding [monitoring.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
            </DockPanel>
            <TextBlock Text="{Binding ExportStatus}" Style="{StaticResource Caption}"
                       Foreground="{DynamicResource Brush.Success}"
                       Visibility="{Binding ExportStatus, Converter={StaticResource NullToCollapsed}}" Margin="0,0,0,8"/>

            <UniformGrid Columns="2">
                <!-- CPU -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left" Text="&#xE950;" Style="{StaticResource SectionIcon}"/>
                            <StackPanel>
                                <TextBlock Text="CPU" Style="{StaticResource H2}" Margin="0"/>
                                <TextBlock Text="{Binding CpuName}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource Metric}"><Run Text="{Binding CpuTemp, Mode=OneWay}"/><Run Text="°C"/></TextBlock>
                            <StackPanel VerticalAlignment="Bottom" Margin="16,0,0,4">
                                <ProgressBar Style="{StaticResource MetricBar}" Width="120" Value="{Binding CpuUsage, Mode=OneWay}"/>
                                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0"><Run Text="{Binding CpuUsage, Mode=OneWay}"/><Run Text="% "/><Run Text="{Binding [monitoring.usage], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/></TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [monitoring.frequency], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding CpuMhz, Mode=OneWay}"/><Run Text=" MHz"/></TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [monitoring.voltage], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding CpuVoltage, Mode=OneWay}"/><Run Text=" V"/></TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [monitoring.power], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding CpuWatt, Mode=OneWay}"/><Run Text=" W"/></TextBlock>
                        </Grid>
                        <TextBlock Text="{Binding [monitoring.per_core], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding PerCoreLoad}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Brush.CardHover}" CornerRadius="5" Padding="8,4" Margin="0,0,5,5" MinWidth="44">
                                        <TextBlock FontSize="11" HorizontalAlignment="Center"><Run Text="{Binding Mode=OneWay}"/><Run Text="%"/></TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ui:LiveGraph Values="{Binding CpuTempHistory}" Height="64" MaxValue="100" Margin="0,10,0,0"
                                      Stroke="{DynamicResource Brush.GraphLine}" Fill="{DynamicResource Brush.GraphFill}"/>
                    </StackPanel>
                </Border>

                <!-- GPU -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left" Text="&#xF211;" Style="{StaticResource SectionIcon}" Foreground="{DynamicResource Brush.AccentSecondary}"/>
                            <StackPanel>
                                <TextBlock Text="GPU" Style="{StaticResource H2}" Margin="0"/>
                                <TextBlock Text="{Binding GpuName}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource Metric}"><Run Text="{Binding GpuTemp, Mode=OneWay}"/><Run Text="°C"/></TextBlock>
                            <StackPanel VerticalAlignment="Bottom" Margin="16,0,0,4">
                                <ProgressBar Style="{StaticResource MetricBar}" Width="120" Value="{Binding GpuUsage, Mode=OneWay}" Foreground="{DynamicResource Brush.AccentSecondary}"/>
                                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0"><Run Text="{Binding GpuUsage, Mode=OneWay}"/><Run Text="% "/><Run Text="{Binding [monitoring.usage], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/></TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VRAM" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding VramUsedMb, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding VramTotalMb, Mode=OneWay}"/><Run Text=" MB"/></TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [monitoring.fan], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding GpuFanRpm, Mode=OneWay}"/><Run Text=" RPM"/></TextBlock>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [monitoring.power], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding GpuWatt, Mode=OneWay}"/><Run Text=" W"/></TextBlock>
                        </Grid>
                        <ui:LiveGraph Values="{Binding GpuTempHistory}" Height="64" MaxValue="100" Margin="0,14,0,0"
                                      Stroke="{DynamicResource Brush.AccentSecondary}" Fill="{DynamicResource Brush.GraphFill}"/>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left" Text="&#xEEA0;" Style="{StaticResource SectionIcon}" Foreground="{DynamicResource Brush.Success}"/>
                            <TextBlock Text="RAM" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource Metric}"><Run Text="{Binding RamUsedGb, Mode=OneWay}"/></TextBlock>
                            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="6,0,0,6"><Run Text="/ "/><Run Text="{Binding RamTotalGb, Mode=OneWay}"/><Run Text=" GB"/></TextBlock>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MHz" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource StatValue}" Margin="0,2"><Run Text="{Binding RamMhz, Mode=OneWay}"/></TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [monitoring.timings], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RamTimings}" Style="{StaticResource StatValue}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [monitoring.temp], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource StatKey}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RamTemp}" Style="{StaticResource StatValue}" Margin="0,2"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mainboard -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left" Text="&#xE964;" Style="{StaticResource SectionIcon}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding [monitoring.mainboard], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="0"/>
                                <TextBlock Text="{Binding MainboardName}" Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="{Binding [monitoring.fans], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding Fans}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatValue}"><Run Text="{Binding Value, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Unit, Mode=OneWay}"/></TextBlock>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource StatKey}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding [monitoring.sensors], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,10,0,4"/>
                        <ItemsControl ItemsSource="{Binding BoardSensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatValue}"><Run Text="{Binding Value, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding Unit, Mode=OneWay}"/></TextBlock>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource StatKey}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Storage -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left" Text="&#xEDA2;" Style="{StaticResource SectionIcon}"/>
                        <TextBlock Text="{Binding [monitoring.storage], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.CardHover}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" Style="{StaticResource Pill}" Background="{DynamicResource Brush.Success}">
                                                <TextBlock FontSize="10" Foreground="Black"><Run Text="SMART "/><Run Text="{Binding SmartStatus, Mode=OneWay}"/></TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0">
                                            <Run Text="{Binding TemperatureC, Mode=OneWay}"/><Run Text=" °C  ·  "/>
                                            <Run Text="{Binding UsedPercent, Mode=OneWay, StringFormat={}{0:0.#}}"/><Run Text="%  ·  R "/>
                                            <Run Text="{Binding ReadMbPerSec, Mode=OneWay, StringFormat={}{0:0.#}}"/><Run Text=" MB/s  ·  W "/>
                                            <Run Text="{Binding WriteMbPerSec, Mode=OneWay, StringFormat={}{0:0.#}}"/><Run Text=" MB/s"/>
                                        </TextBlock>
                                        <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding UsedPercent, Mode=OneWay}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
