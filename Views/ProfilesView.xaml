<UserControl x:Class="BKKleaner.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                Command="{Binding OpenCreateCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding [profiles.new], Source={x:Static loc:Loc.Instance}}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="{Binding [profiles.rollback], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding UndoActiveCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding [profiles.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
                </DockPanel>

                <CheckBox IsChecked="{Binding RunBenchmarkComparison}" Margin="0,0,0,8"
                          Content="{Binding [profiles.benchmark_compare], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,0,0,4"
                           Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
                <TextBlock Text="{Binding ComparisonText}" Style="{StaticResource Caption}" Margin="0,0,0,8"
                           Foreground="{DynamicResource Brush.Success}"
                           Visibility="{Binding ComparisonText, Converter={StaticResource NullToCollapsed}}"/>

                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Style="{StaticResource Pill}" Background="{DynamicResource Brush.Accent}"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding [profiles.active], Source={x:Static loc:Loc.Instance}}" FontSize="10" Foreground="{DynamicResource Brush.OnAccent}"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Caption}" Margin="0,6,0,8" MinHeight="32"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,8">
                                        <Run Text="{Binding [profiles.action_count], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/><Run Text=": "/><Run Text="{Binding ActionCount, Mode=OneWay}"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                                                Content="{Binding [profiles.apply], Source={x:Static loc:Loc.Instance}}"
                                                Command="{Binding ApplyCommand}"/>
                                        <Button Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                                                Content="{Binding [opt.preview], Source={x:Static loc:Loc.Instance}}"
                                                Command="{Binding PreviewCommand}"/>
                                        <Button Style="{StaticResource GhostButton}" Command="{Binding ToggleEditCommand}"
                                                ToolTip="{Binding [profiles.edit], Source={x:Static loc:Loc.Instance}}">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostButton}" Command="{Binding DeleteCommand}"
                                                ToolTip="{Binding [profiles.delete], Source={x:Static loc:Loc.Instance}}"
                                                Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Danger}"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Inline editor -->
                                    <Border Margin="0,10,0,0" Padding="12" CornerRadius="8"
                                            Background="{DynamicResource Brush.CardHover}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [profiles.edit_actions], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                                            <ItemsControl ItemsSource="{Binding EditableActions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsIncluded}" Content="{Binding Title}" FontSize="12" Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Padding="12,6"
                                                        Content="{Binding [profiles.save], Source={x:Static loc:Loc.Instance}}"
                                                        Command="{Binding SaveEditCommand}"/>
                                                <Button Style="{StaticResource SecondaryButton}" Padding="12,6"
                                                        Content="{Binding [profiles.reset], Source={x:Static loc:Loc.Instance}}"
                                                        Command="{Binding ResetEditCommand}"
                                                        Visibility="{Binding CanReset, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Preview overlay panel -->
        <Border Background="{DynamicResource Brush.Overlay}" Visibility="{Binding IsPreviewOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" MaxWidth="560" MaxHeight="520" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="22">
                <Border.Effect><DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.45" Color="Black"/></Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Command="{Binding ClosePreviewCommand}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <TextBlock Text="{Binding PreviewTitle}" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding [profiles.preview_subtitle], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding PreviewText}" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.Text}"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- Create profile overlay panel -->
        <Border Background="{DynamicResource Brush.Overlay}" Visibility="{Binding IsCreateOpen, Converter={StaticResource BoolToVisibility}}">
            <Border Style="{StaticResource Card}" MaxWidth="560" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="22">
                <Border.Effect><DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.45" Color="Black"/></Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Command="{Binding CancelCreateCommand}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <TextBlock Text="{Binding [profiles.new], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding [profiles.name], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                    <TextBox DockPanel.Dock="Top" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                Content="{Binding [profiles.create_btn], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding ConfirmCreateCommand}"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="{Binding [profiles.cancel], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding CancelCreateCommand}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding [profiles.edit_actions], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NewProfileActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsIncluded}" Content="{Binding Title}" FontSize="12" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusText}"/>
    </Grid>
</UserControl>
