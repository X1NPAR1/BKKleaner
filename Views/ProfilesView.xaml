<UserControl x:Class="BKKleaner.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                            Content="{Binding [profiles.rollback], Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding UndoActiveCommand}" VerticalAlignment="Top"/>
                    <TextBlock Text="{Binding [profiles.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
                </DockPanel>

                <CheckBox IsChecked="{Binding RunBenchmarkComparison}" Margin="0,0,0,8"
                          Content="{Binding [profiles.benchmark_compare], Source={x:Static loc:Loc.Instance}}"/>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,0,0,4"
                           Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
                <TextBlock Text="{Binding ComparisonText}" Style="{StaticResource Caption}" Margin="0,0,0,8"
                           Foreground="{DynamicResource Brush.Success}"
                           Visibility="{Binding ComparisonText, Converter={StaticResource NullToCollapsed}}"/>

                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Style="{StaticResource Pill}" Background="{DynamicResource Brush.Accent}"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding [profiles.active], Source={x:Static loc:Loc.Instance}}" FontSize="10" Foreground="{DynamicResource Brush.OnAccent}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Caption}" Margin="0,6,0,8" MinHeight="32"/>
                                    <TextBlock Style="{StaticResource Caption}" Margin="0,0,0,8">
                                        <Run Text="{Binding [profiles.action_count], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/><Run Text=": "/><Run Text="{Binding ActionCount, Mode=OneWay}"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                Content="{Binding [profiles.apply], Source={x:Static loc:Loc.Instance}}"
                                                Command="{Binding ApplyCommand}"/>
                                        <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                                Content="{Binding [opt.preview], Source={x:Static loc:Loc.Instance}}"
                                                Command="{Binding PreviewCommand}"/>
                                        <Button Style="{StaticResource GhostButton}"
                                                Command="{Binding ToggleEditCommand}" ToolTip="{Binding [profiles.edit], Source={x:Static loc:Loc.Instance}}">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Edit panel -->
                                    <Border Margin="0,10,0,0" Padding="12" CornerRadius="8"
                                            Background="{DynamicResource Brush.CardHover}"
                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [profiles.edit_actions], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,6"/>
                                            <ItemsControl ItemsSource="{Binding EditableActions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsIncluded}" Content="{Binding Title}" FontSize="12" Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Padding="12,6"
                                                        Content="{Binding [profiles.save], Source={x:Static loc:Loc.Instance}}"
                                                        Command="{Binding SaveEditCommand}"/>
                                                <Button Style="{StaticResource SecondaryButton}" Padding="12,6"
                                                        Content="{Binding [profiles.reset], Source={x:Static loc:Loc.Instance}}"
                                                        Command="{Binding ResetEditCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding PreviewText}" Style="{StaticResource Caption}" FontFamily="Consolas" Margin="0,8,0,0"
                                               Visibility="{Binding PreviewText, Converter={StaticResource NullToCollapsed}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusText}"/>
    </Grid>
</UserControl>
