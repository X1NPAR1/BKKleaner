<UserControl x:Class="BKKleaner.Views.UpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding [updates.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                Content="{Binding [updates.check], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding CheckCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="{Binding [updates.drivers], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding OpenWindowsUpdateCommand}"/>
                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="14,0,0,0" Style="{StaticResource Caption}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SelfUpdateText}" Style="{StaticResource Caption}" Margin="0,8,0,0"
                               Visibility="{Binding SelfUpdateText, Converter={StaticResource NullToCollapsed}}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ListBox ItemsSource="{Binding Items}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="0,4">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                    Content="{Binding [updates.install], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding DataContext.UpgradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Style="{StaticResource Caption}">
                                    <Run Text="{Binding Kind, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding CurrentVersion, Mode=OneWay}"/><Run Text=" → "/><Run Text="{Binding AvailableVersion, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
