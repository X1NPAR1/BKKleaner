<Window x:Class="BKKleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BKKleaner.ViewModels"
        xmlns:ui="clr-namespace:BKKleaner.UI"
        xmlns:loc="clr-namespace:BKKleaner.Localization"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="BKKleaner" Height="780" Width="1280" MinHeight="620" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="TrayMenuItem" TargetType="MenuItem">
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- System tray icon -->
        <tb:TaskbarIcon x:Name="Tray"
                        ToolTipText="BKKleaner"
                        DoubleClickCommand="{Binding TrayOpenCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding [tray.open], Source={x:Static loc:Loc.Instance}}"
                              Command="{Binding TrayOpenCommand}" Style="{StaticResource TrayMenuItem}"/>
                    <MenuItem Header="{Binding [tray.clean_ram], Source={x:Static loc:Loc.Instance}}"
                              Command="{Binding TrayCleanRamCommand}" Style="{StaticResource TrayMenuItem}"/>
                    <Separator/>
                    <MenuItem Header="{Binding [tray.exit], Source={x:Static loc:Loc.Instance}}"
                              Command="{Binding TrayExitCommand}" Style="{StaticResource TrayMenuItem}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="234"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource Brush.Sidebar}"
                    BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="20,22,20,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource Brush.Accent}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                                           Foreground="{DynamicResource Brush.OnAccent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="BKKleaner" FontSize="19" FontWeight="Bold"
                                           Foreground="{DynamicResource Brush.Text}"/>
                                <Border Style="{StaticResource Pill}" HorizontalAlignment="Left" Margin="0,2,0,0"
                                        Background="{DynamicResource Brush.CardHover}">
                                    <TextBlock Text="{Binding AdminBadge}" FontSize="10"
                                               Foreground="{DynamicResource Brush.TextSecondary}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Version}"
                               Style="{StaticResource Caption}" Margin="22,8,0,16"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavigationItem}">
                                    <RadioButton Style="{StaticResource NavButton}"
                                                 GroupName="Nav"
                                                 IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                 Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16" Width="24" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ui:TransitioningContentControl Grid.Column="1" Margin="24,20,12,8"
                                            Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
