<Window x:Class="BKKleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BKKleaner.ViewModels"
        xmlns:loc="clr-namespace:BKKleaner.Localization"
        Title="BKKleaner" Height="760" Width="1240" MinHeight="600" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource Brush.Sidebar}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,22,20,14">
                    <TextBlock Text="BKKleaner" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Accent}"/>
                    <TextBlock Text="{Binding AdminBadge}" Style="{StaticResource Caption}" Margin="1,4,0,0"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0 · X1NPAR1"
                           Style="{StaticResource Caption}" Margin="22,0,0,16"/>

                <ItemsControl ItemsSource="{Binding NavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavigationItem}">
                            <RadioButton Style="{StaticResource NavButton}"
                                         GroupName="Nav"
                                         IsChecked="{Binding IsSelected, Mode=OneWay}"
                                         Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Title}" FontSize="14"/>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Margin="24,20,12,8"
                        Style="{StaticResource PageHost}"
                        Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>
