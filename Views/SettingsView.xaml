<UserControl x:Class="BKKleaner.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{Binding [settings.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding [settings.appearance], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{Binding [settings.language], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding [settings.theme], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                        Content="{Binding [settings.custom_theme], Source={x:Static loc:Loc.Instance}}"
                                        Command="{Binding LoadCustomThemeCommand}"/>
                                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}"/>
                            </DockPanel>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding [settings.monitoring], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="{Binding [settings.interval], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MonitoringIntervalMs}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding [settings.cpu_warn], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CpuTempWarning}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{Binding [settings.gpu_warn], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding GpuTempWarning}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding [settings.ram_warn], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding RamUsageWarning}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding [settings.behavior], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    <CheckBox IsChecked="{Binding MinimizeToTray}"
                              Content="{Binding [settings.minimize_tray], Source={x:Static loc:Loc.Instance}}"/>
                    <CheckBox IsChecked="{Binding CloseToTray}"
                              Content="{Binding [settings.close_tray], Source={x:Static loc:Loc.Instance}}"/>
                    <CheckBox IsChecked="{Binding EnableAnimations}"
                              Content="{Binding [settings.animations], Source={x:Static loc:Loc.Instance}}"/>
                    <CheckBox IsChecked="{Binding StartWithWindows}"
                              Content="{Binding [settings.start_with_windows], Source={x:Static loc:Loc.Instance}}"/>
                    <CheckBox IsChecked="{Binding StartMinimized}" Margin="24,5,0,5"
                              IsEnabled="{Binding StartWithWindows}"
                              Content="{Binding [settings.start_minimized], Source={x:Static loc:Loc.Instance}}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding [settings.auto_ram], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    <CheckBox IsChecked="{Binding AutoRamCleanEnabled}"
                              Content="{Binding [settings.auto_ram_enable], Source={x:Static loc:Loc.Instance}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" IsEnabled="{Binding AutoRamCleanEnabled}">
                        <TextBlock Text="{Binding [settings.auto_ram_interval], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding AutoRamIntervals}" SelectedItem="{Binding AutoRamCleanInterval}" MinWidth="110">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Mode=OneWay, Converter={StaticResource MinutesLabel}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding [settings.safety], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    <CheckBox IsChecked="{Binding CreateRestorePoint}"
                              Content="{Binding [settings.restore_point], Source={x:Static loc:Loc.Instance}}"/>
                    <CheckBox IsChecked="{Binding WebhookEnabled}"
                              Content="{Binding [settings.webhook], Source={x:Static loc:Loc.Instance}}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                        Content="{Binding [settings.save], Source={x:Static loc:Loc.Instance}}"
                        Command="{Binding SaveCommand}"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Content="{Binding [settings.validate_translations], Source={x:Static loc:Loc.Instance}}"
                        Command="{Binding ValidateTranslationsCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding ValidationText}" Style="{StaticResource Caption}" Margin="0,8,0,0"
                       Visibility="{Binding ValidationText, Converter={StaticResource NullToCollapsed}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
