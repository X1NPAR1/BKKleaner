<UserControl x:Class="BKKleaner.Views.BenchmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding [bench.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding [bench.subtitle], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                    Command="{Binding RunCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [bench.run], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="{Binding [bench.set_baseline], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding MarkAsBaselineCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding StatusText}" Margin="0,10,0,0" Style="{StaticResource Caption}"
                                   Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="{Binding LastResult, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel DataContext="{Binding LastResult}">
                        <TextBlock Text="{Binding [bench.last_result], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <UniformGrid Columns="4">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="{Binding [bench.fps], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding FpsEstimate}" Style="{StaticResource Metric}" Foreground="{DynamicResource Brush.Accent}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="{Binding [bench.cpu_st], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding CpuSingleThreadScore, Converter={StaticResource ScoreLabel}}" Style="{StaticResource Metric}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="{Binding [bench.cpu_mt], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <TextBlock Text="{Binding CpuMultiThreadScore, Converter={StaticResource ScoreLabel}}" Style="{StaticResource Metric}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding [bench.mem], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <TextBlock Style="{StaticResource Metric}"><Run Text="{Binding MemoryBandwidthMbps, Mode=OneWay, StringFormat={}{0:N0}}"/></TextBlock>
                            </StackPanel>
                        </UniformGrid>
                        <Border Background="{DynamicResource Brush.CardHover}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource Caption}">
                                <Run Text="{Binding [bench.latency], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/><Run Text=": "/><Run Text="{Binding LatencyMs, Mode=OneWay}"/><Run Text=" ms   ·   "/><Run Text="{Binding [bench.cpu_load], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/><Run Text=" "/><Run Text="{Binding CpuLoadPercent, Mode=OneWay}"/><Run Text="%   ·   RAM "/><Run Text="{Binding RamUsagePercent, Mode=OneWay}"/><Run Text="%"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="{Binding ComparisonText, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [bench.comparison], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <TextBlock Text="{Binding ComparisonText}" Foreground="{DynamicResource Brush.Success}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ReportPath}" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusText}"/>
    </Grid>
</UserControl>
