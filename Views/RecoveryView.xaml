<UserControl x:Class="BKKleaner.Views.RecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Content="{Binding [recovery.create_backup], Source={x:Static loc:Loc.Instance}}"
                        Command="{Binding CreateFullBackupCommand}" VerticalAlignment="Top"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                <TextBlock Text="{Binding [recovery.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
            </DockPanel>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,0,0,8"
                       Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ListBox ItemsSource="{Binding Points}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="0,4">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                    Content="{Binding [recovery.restore], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold"/>
                                <TextBlock Style="{StaticResource Caption}">
                                    <Run Text="{Binding Kind, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding CreatedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
