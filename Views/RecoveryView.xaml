<UserControl x:Class="BKKleaner.Views.RecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" VerticalAlignment="Top"
                            Command="{Binding CreateFullBackupCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [recovery.create_backup], Source={x:Static loc:Loc.Instance}}"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding [recovery.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
                </DockPanel>
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource Caption}" Margin="0,0,0,8"
                           Foreground="{DynamicResource Brush.Success}"
                           Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupedPoints}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Border Background="{DynamicResource Brush.CardHover}" CornerRadius="10"
                                                                Padding="14,12" Margin="0,0,0,12">
                                                            <StackPanel>
                                                                <!-- Session date-time header -->
                                                                <DockPanel Margin="0,0,0,8">
                                                                    <Border DockPanel.Dock="Right" Style="{StaticResource Pill}"
                                                                            Background="{DynamicResource Brush.Accent}">
                                                                        <TextBlock Foreground="{DynamicResource Brush.OnAccent}" FontSize="11" FontWeight="SemiBold">
                                                                            <Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding [recovery.items], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/>
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                                                                   Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                                <ItemsPresenter/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Brush.Card}" CornerRadius="7" Padding="12,9" Margin="0,3">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Padding="12,6"
                                                    Content="{Binding [recovery.restore], Source={x:Static loc:Loc.Instance}}"
                                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock DockPanel.Dock="Left" Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Style="{StaticResource Caption}">
                                                    <Run Text="{Binding KindLabel, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding Time, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                                Visibility="{Binding Points.Count, Converter={StaticResource EmptyToVisible}}">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="40" Opacity="0.4"
                                   Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding [recovery.empty], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusText}"/>
    </Grid>
</UserControl>
