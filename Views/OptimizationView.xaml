<UserControl x:Class="BKKleaner.Views.OptimizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization"
             Loaded="OnLoaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" VerticalAlignment="Top"
                            Command="{Binding UndoAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [opt.undo_all], Source={x:Static loc:Loc.Instance}}"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding [opt.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
                </DockPanel>

                <Border Style="{StaticResource Card}" Padding="14">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource Pill}" Background="{DynamicResource Brush.Accent}">
                            <TextBlock Foreground="{DynamicResource Brush.OnAccent}" FontWeight="SemiBold"><Run Text="{Binding AppliedCount, Mode=OneWay}"/><Run Text=" "/><Run Text="{Binding [opt.applied_count], Mode=OneWay, Source={x:Static loc:Loc.Instance}}"/></TextBlock>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}"/>
                        <TextBlock Text="{Binding [opt.subtitle], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" VerticalAlignment="Center"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}, ConverterParameter=invert}"/>
                    </DockPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding GroupedActions}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H2}" Margin="2,14,0,8"
                                               Foreground="{DynamicResource Brush.TextSecondary}" FontSize="13"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16,14">
                                <StackPanel>
                                    <DockPanel>
                                        <!-- Toggle switch -->
                                        <ToggleButton DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                                                      IsChecked="{Binding IsApplied, Mode=OneWay}"
                                                      Command="{Binding ToggleCommand}"
                                                      IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                                      Cursor="Hand">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Track" Width="46" Height="26" CornerRadius="13"
                                                            Background="{DynamicResource Brush.CardHover}">
                                                        <Ellipse x:Name="Knob" Width="20" Height="20" HorizontalAlignment="Left"
                                                                 Margin="3,0,0,0" Fill="{DynamicResource Brush.TextSecondary}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.Accent}"/>
                                                            <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                                            <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0"/>
                                                            <Setter TargetName="Knob" Property="Fill" Value="{DynamicResource Brush.OnAccent}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding CategoryGlyph}" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="18" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Top" Margin="0,2,14,0"/>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                                <Border Style="{StaticResource Pill}" Background="{DynamicResource Brush.Warning}" Margin="8,0,0,0"
                                                        Visibility="{Binding RequiresRestart, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding [opt.restart_required], Source={x:Static loc:Loc.Instance}}" FontSize="10" Foreground="Black"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding PreviewText}" Style="{StaticResource Caption}" FontFamily="Consolas" Margin="0,8,0,0"
                                                       Visibility="{Binding PreviewText, Converter={StaticResource NullToCollapsed}}"/>
                                            <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,6,0,0" Padding="0,2"
                                                    Command="{Binding PreviewCommand}">
                                                <TextBlock Text="{Binding [opt.preview], Source={x:Static loc:Loc.Instance}}" FontSize="11" Foreground="{DynamicResource Brush.Accent}"/>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Startup programs -->
                <Border Style="{StaticResource Card}" Margin="0,8,12,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Padding="12,6"
                                    Content="{Binding [opt.refresh], Source={x:Static loc:Loc.Instance}}"
                                    Command="{Binding LoadStartupCommand}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B5;" Style="{StaticResource SectionIcon}"/>
                                <TextBlock Text="{Binding [opt.startup], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding StartupEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Brush.CardHover}" CornerRadius="7" Padding="12,8" Margin="0,0,0,6">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" MinWidth="100" Padding="12,6"
                                                    Command="{Binding DataContext.ToggleStartupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Content>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding [opt.enable], Source={x:Static loc:Loc.Instance}}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                        <Setter Property="Text" Value="{Binding [opt.disable], Source={x:Static loc:Loc.Instance}}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button.Content>
                                            </Button>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Location, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Command, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusMessage}"/>
    </Grid>
</UserControl>
