<UserControl x:Class="BKKleaner.Views.OptimizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BKKleaner.Localization"
             Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                        Content="{Binding [opt.undo_all], Source={x:Static loc:Loc.Instance}}"
                        Command="{Binding UndoAllCommand}" VerticalAlignment="Top"/>
                <TextBlock Text="{Binding [opt.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
            </DockPanel>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToCollapsed}}" Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding Actions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                            Content="{Binding [opt.preview], Source={x:Static loc:Loc.Instance}}"
                                            Command="{Binding PreviewCommand}"/>
                                    <Button Style="{StaticResource PrimaryButton}" MinWidth="110"
                                            Command="{Binding ToggleCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                        <Button.Content>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding [opt.apply], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsApplied}" Value="True">
                                                                <Setter Property="Text" Value="{Binding [opt.undo], Source={x:Static loc:Loc.Instance}}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                        <Border Background="{DynamicResource Brush.Success}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                Visibility="{Binding IsApplied, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding [opt.applied], Source={x:Static loc:Loc.Instance}}" FontSize="10" Foreground="Black"/>
                                        </Border>
                                        <Border Background="{DynamicResource Brush.Warning}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                                Visibility="{Binding RequiresRestart, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding [opt.restart_required], Source={x:Static loc:Loc.Instance}}" FontSize="10" Foreground="Black"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding PreviewText}" Style="{StaticResource Caption}" FontFamily="Consolas" Margin="0,6,0,0"
                                               Visibility="{Binding PreviewText, Converter={StaticResource NullToCollapsed}}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                Content="{Binding [opt.refresh], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding LoadStartupCommand}"/>
                        <TextBlock Text="{Binding [opt.startup], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding StartupEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,4">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" MinWidth="100"
                                            Command="{Binding DataContext.ToggleStartupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Content>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding [opt.enable], Source={x:Static loc:Loc.Instance}}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                <Setter Property="Text" Value="{Binding [opt.disable], Source={x:Static loc:Loc.Instance}}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button.Content>
                                    </Button>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding Location, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Command, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
