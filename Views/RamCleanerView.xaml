<UserControl x:Class="BKKleaner.Views.RamCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding [ram.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{Binding [ram.options], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <CheckBox IsChecked="{Binding TrimWorkingSets}"
                                  Content="{Binding [ram.trim], Source={x:Static loc:Loc.Instance}}"/>
                        <CheckBox IsChecked="{Binding ClearStandbyList}"
                                  Content="{Binding [ram.standby], Source={x:Static loc:Loc.Instance}}"/>
                        <CheckBox IsChecked="{Binding OptimizeCache}"
                                  Content="{Binding [ram.cache], Source={x:Static loc:Loc.Instance}}"/>
                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,12,0,0"
                                Content="{Binding [ram.clean_now], Source={x:Static loc:Loc.Instance}}"
                                Command="{Binding CleanCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="{Binding ResultText, Converter={StaticResource NullToCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="{Binding [ram.result], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                        <TextBlock Text="{Binding ResultText}"/>
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding [ram.before], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding UsageBefore, Mode=OneWay}" Margin="0,4,12,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding [ram.after], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                                <ProgressBar Style="{StaticResource MetricBar}" Value="{Binding UsageAfter, Mode=OneWay}"
                                             Foreground="{DynamicResource Brush.Success}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Automatic RAM cleaning -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding [ram.auto_title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding [ram.auto_desc], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}" Margin="0,0,0,10"/>
                        <CheckBox IsChecked="{Binding AutoEnabled}"
                                  Content="{Binding [ram.auto_enable], Source={x:Static loc:Loc.Instance}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    IsEnabled="{Binding AutoEnabled}">
                            <TextBlock Text="{Binding [ram.auto_interval], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox ItemsSource="{Binding AutoIntervals}" SelectedItem="{Binding AutoInterval}" MinWidth="110">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Mode=OneWay, Converter={StaticResource MinutesLabel}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="{Binding AutoStatus}" Style="{StaticResource Caption}" Margin="0,10,0,0"
                                   Foreground="{DynamicResource Brush.Success}"
                                   Visibility="{Binding AutoStatus, Converter={StaticResource NullToCollapsed}}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <TextBlock Text="{Binding [ram.safety_note], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding [ram.cleaning], Source={x:Static loc:Loc.Instance}}"/>
    </Grid>
</UserControl>
