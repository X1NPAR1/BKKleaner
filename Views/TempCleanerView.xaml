<UserControl x:Class="BKKleaner.Views.TempCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:BKKleaner.UI"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <Grid Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="{Binding [temp.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                                <TextBlock Text="{Binding [temp.mode], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" MinWidth="130">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumLabel}, ConverterParameter=temp.cleanmode}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                    Command="{Binding ScanCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [temp.scan], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                    Command="{Binding CleanCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [temp.clean], Source={x:Static loc:Loc.Instance}}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Right" Style="{StaticResource Pill}" Background="{DynamicResource Brush.Accent}"
                                    Visibility="{Binding TotalSizeMb, Converter={StaticResource TrueToVisible}}">
                                <TextBlock Foreground="{DynamicResource Brush.OnAccent}" FontWeight="SemiBold"><Run Text="{Binding TotalSizeMb, Mode=OneWay}"/><Run Text=" MB"/></TextBlock>
                            </Border>
                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Style="{StaticResource Caption}"
                                       Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                <Grid>
                    <ListBox ItemsSource="{Binding Items}" VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="2">
                                    <CheckBox IsChecked="{Binding Selected}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource StatValue}" VerticalAlignment="Center"
                                               Text="{Binding SizeBytes, Converter={StaticResource BytesToMb}}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                        <TextBlock Text="{Binding Category, Converter={StaticResource EnumLabel}, ConverterParameter=temp.cat}"
                                                   Style="{StaticResource Caption}" FontSize="10"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                                Visibility="{Binding Items.Count, Converter={StaticResource EmptyToVisible}}">
                        <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="40" Opacity="0.4"
                                   Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding [temp.hint], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource Caption}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}"
                    Visibility="{Binding Snapshots.Count, Converter={StaticResource TrueToVisible}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE7A7;" Style="{StaticResource SectionIcon}"/>
                        <TextBlock Text="{Binding [temp.restore_title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}" Margin="0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Snapshots}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,6" Padding="12,6"
                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <TextBlock><Run Text="&#xE7A7;  " FontFamily="Segoe MDL2 Assets"/><Run Text="{Binding Mode=OneWay}"/></TextBlock>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <ui:BusyOverlay IsActive="{Binding IsBusy}" Message="{Binding StatusText}"/>
    </Grid>
</UserControl>
