<UserControl x:Class="BKKleaner.Views.TempCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:BKKleaner.Localization">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding [temp.title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H1}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [temp.mode], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" Margin="0,0,12,0"/>
                    <Button Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            Content="{Binding [temp.scan], Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding ScanCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{Binding [temp.clean], Source={x:Static loc:Loc.Instance}}"
                            Command="{Binding CleanCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="14,0,0,0"
                               Style="{StaticResource Caption}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ListBox ItemsSource="{Binding Items}" VirtualizingPanel.IsVirtualizing="True">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <CheckBox IsChecked="{Binding Selected}" Margin="0,0,8,0"/>
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Caption}"
                                       Text="{Binding SizeBytes, Converter={StaticResource BytesToMb}}"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                <TextBlock Text="{Binding Category}" Style="{StaticResource Caption}" FontSize="10"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="{Binding [temp.restore_title], Source={x:Static loc:Loc.Instance}}" Style="{StaticResource H2}"/>
                <ItemsControl ItemsSource="{Binding Snapshots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,6"
                                    Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <TextBlock><Run Text="↩ "/><Run Text="{Binding Mode=OneWay}"/></TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
